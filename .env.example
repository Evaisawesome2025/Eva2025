# ---------------------------------------------------------------------------
# Sioux Falls Flip Radar — environment variables
# Copy this file to `.env` (and `.env.local` for Next.js client/runtime vars)
# and fill in your own keys. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# --- Database (Prisma -> Supabase Postgres) ---
# Use the Supabase "Connection string" (transaction pooler for serverless).
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Google Maps / Places (address autocomplete + geocoding) ---
# Browser key is restricted to your domain; used by the autocomplete widget.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-browser-key"
# Server key for Geocoding API calls (county lookup, validation).
GOOGLE_GEOCODING_API_KEY="your-google-geocoding-server-key"

# --- Approved data provider APIs (optional, add when you sign up) ---
RENTCAST_API_KEY=""
ATTOM_API_KEY=""
# --- County GIS open data (KEYLESS, our own data layer) ---
# Public county ArcGIS parcel layer — powers free, no-API property facts + comps.
# Point it at a queryable layer and map the field names to that layer's
# attributes (inspect with `?f=json`). Example for Sioux Falls (Minnehaha Co.):
#   https://gis.minnehahacounty.org/minnemap/rest/services/Parcels/MapServer/0
COUNTY_GIS_PARCELS_URL=""
COUNTY_GIS_API_KEY=""
COUNTY_GIS_ADDRESS_FIELD="SiteAddress"
COUNTY_GIS_PARCELID_FIELD="ParcelID"
COUNTY_GIS_OWNER_FIELD="Owner"
COUNTY_GIS_SQFT_FIELD="BuildingSqFt"
COUNTY_GIS_YEARBUILT_FIELD="YearBuilt"
COUNTY_GIS_ASSESSEDVALUE_FIELD="TotalValue"
COUNTY_GIS_SALEPRICE_FIELD="SalePrice"
COUNTY_GIS_SALEDATE_FIELD="SaleDate"

# --- MLS / IDX broker feed (optional, when you have a licensed feed) ---
MLS_IDX_BASE_URL=""
MLS_IDX_API_KEY=""
