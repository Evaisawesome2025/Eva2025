# Copy to config/credentials.env (gitignored) and fill in. Never commit real secrets.

# --- Google Ads + Local Services Ads ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# --- Meta (Facebook/Instagram) Ads ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# --- GA4 + Search Console ---
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=config/service-account.json
SEARCH_CONSOLE_SITE_URL=

# --- Call tracking (CallRail / WhatConverts / etc.) ---
CALL_TRACKING_API_KEY=
CALL_TRACKING_ACCOUNT_ID=

# --- Google Business Profile ---
GBP_LOCATION_ID=

# --- Website ---
# WordPress:
WP_BASE_URL=
WP_USERNAME=
WP_APP_PASSWORD=
# or git-based site:
SITE_REPO_PATH=
