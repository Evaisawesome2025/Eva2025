# Copy this file to credentials.env and fill in what you have. NEVER commit credentials.env.
# The crew works with whatever is present — start with just the Anthropic key and add the rest later.

# Required: lets the agents think. Get one at https://console.anthropic.com
# Note: this is API usage (pay per use), separate from a Claude Pro subscription.
ANTHROPIC_API_KEY=

# Optional — only needed by the agents that touch these services:

# Tara (lead finder) — Reddit API for richer searching. Without it she uses web search.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Sara (outreach) / Maya (inbox) — if you later want an approved send/read step.
# Leave blank to keep everything draft-only (recommended to start).
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Nova (reputation) — review platform API (e.g. Google Business Profile) if you connect one.
GOOGLE_BUSINESS_PROFILE_TOKEN=
